# cs-repo environment variables — copy to .env and fill in your values.
# .env is gitignored; this file is the template.

# Path to your Obsidian vault root. Used by hooks/session-to-obsidian.py to
# export session transcripts on session exit. Leave unset to disable export.
OBSIDIAN_VAULT=/path/to/your/obsidian/vault

# JSON map of cwd substring → Obsidian note name for auto-tagging exported
# sessions. Overrides the in-file PROJECT_MAP_FALLBACK in session-to-obsidian.py.
# Example:
#   OBSIDIAN_PROJECT_MAP={"cs-repo":"CS Repo","client-acme":"Acme Client"}
OBSIDIAN_PROJECT_MAP={"cs-repo":"CS Repo"}
