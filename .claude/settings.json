            "type": "command",
            "command": "python3 hooks/push-guard.py",
            "statusMessage": "Checking push commands..."
          },
          {
            "type": "command",
            "command": "python3 hooks/block-attribution.py",
            "statusMessage": "Checking commit attribution..."
          },
          {
            "type": "command",
            "command": "python3 hooks/secret-scan.py",
            "statusMessage": "Scanning staged diff for secrets...",
            "timeout": 15
          }
        ]
      },
