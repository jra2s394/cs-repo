{
  "autoUpdatesChannel": "stable",
  "disableSkillShellExecution": true,
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "filesystem": {
      "denyRead": ["~/.ssh", "~/.aws", "~/.gnupg"]
    },
    "network": {
      "allowedDomains": [
        "api.github.com",
        "github.com",
        "registry.npmjs.org",
        "files.pythonhosted.org",
        "pypi.org",
        "code.claude.com",
        "anthropic.com"
      ]
    },
    "excludedCommands": ["gh *", "git *", "pip *", "pip3 *", "npm *", "npx *"]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/branch-enforcer.py",
            "statusMessage": "Checking branch protection..."
          },
          {
            "type": "command",
            "command": "python3 hooks/push-guard.py",
            "statusMessage": "Checking push commands..."
          },
          {
            "type": "command",
            "command": "python3 hooks/block-attribution.py",
            "statusMessage": "Checking commit attribution..."
          },
          {
            "type": "command",
            "command": "python3 hooks/secret-scan.py",
            "statusMessage": "Scanning staged diff for secrets...",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/file-protector.py",
            "statusMessage": "Checking file protection..."
          }
        ]
      },
      {
        "matcher": "mcp__claude_ai_Intercom__create_article|mcp__claude_ai_Intercom__update_article|mcp__claude_ai_Asana__create_tasks|mcp__claude_ai_Asana__update_tasks|mcp__claude_ai_Asana__create_project|mcp__claude_ai_Asana__create_project_confirm|mcp__claude_ai_Asana__create_project_confirm_populate|mcp__claude_ai_Asana__create_task_confirm|mcp__claude_ai_Asana__save_task_changes_confirm|mcp__claude_ai_Asana__save_project_changes_confirm|mcp__claude_ai_Asana__add_comment|mcp__claude_ai_Slack__slack_send_message|mcp__claude_ai_Slack__slack_schedule_message|mcp__claude_ai_Slack__slack_send_message_draft|mcp__claude_ai_Slack__slack_create_canvas|mcp__claude_ai_Slack__slack_update_canvas|mcp__claude_ai_Google_Calendar__create_event|mcp__claude_ai_Google_Calendar__update_event|mcp__claude_ai_Google_Calendar__respond_to_event|mcp__claude_ai_Google_Drive__create_file|mcp__claude_ai_Google_Drive__copy_file|mcp__claude_ai_Gmail__create_draft|mcp__claude_ai_Gmail__create_label|mcp__claude_ai_Gmail__update_label|mcp__claude_ai_Gmail__delete_label|mcp__claude_ai_Gmail__label_message|mcp__claude_ai_Gmail__label_thread|mcp__claude_ai_Gmail__unlabel_message|mcp__claude_ai_Gmail__unlabel_thread|mcp__shortcut__stories-create|mcp__shortcut__stories-update|mcp__shortcut__stories-create-comment|mcp__shortcut__stories-add-task|mcp__shortcut__stories-update-task|mcp__shortcut__stories-add-relation|mcp__shortcut__stories-assign-current-user|mcp__shortcut__stories-unassign-current-user|mcp__shortcut__stories-add-external-link|mcp__shortcut__stories-remove-external-link|mcp__shortcut__stories-set-external-links|mcp__shortcut__stories-add-subtask|mcp__shortcut__stories-create-subtask|mcp__shortcut__stories-remove-subtask|mcp__shortcut__stories-upload-file|mcp__shortcut__epics-create|mcp__shortcut__epics-update|mcp__shortcut__epics-create-comment|mcp__shortcut__iterations-create|mcp__shortcut__iterations-update|mcp__shortcut__documents-create|mcp__shortcut__documents-update|mcp__shortcut__labels-create",
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/draft-before-create.py",
            "statusMessage": "Enforcing Draft-Before-Create..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/audit-log.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/lint-after-edit.py",
            "statusMessage": "Linting edited file...",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/audit-log.py",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/audit-log.py",
            "timeout": 5,
            "statusMessage": "Logging subagent start..."
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/audit-log.py",
            "timeout": 5,
            "statusMessage": "Logging subagent stop..."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/compact-reinject.py",
            "statusMessage": "Re-injecting critical rules into compacted context..."
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/notify.py",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/pr-template-reminder.py",
            "statusMessage": "Checking for PR template..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/session-to-obsidian.py",
            "async": true,
            "statusMessage": "Exporting session to Obsidian...",
            "timeout": 30
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/config-change-audit.py",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(shellcheck *)",
      "mcp__claude_ai_Slack__slack_search_channels",
      "mcp__claude_ai_Slack__slack_search_public_and_private"
    ],
    "deny": [
      "mcp__claude_ai_Asana__delete_task",
      "mcp__claude_ai_Asana__create_project_status_update",
      "mcp__claude_ai_Google_Calendar__delete_event",
      "mcp__shortcut__stories-delete",
      "mcp__shortcut__epics-delete",
      "mcp__shortcut__iterations-delete"
    ],
    "disableBypassPermissionsMode": "disable"
  }
}
