{
  "autoUpdatesChannel": "stable",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/branch-enforcer.py",
            "statusMessage": "Checking branch protection..."
          },
