        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/pr-template-reminder.py",
            "statusMessage": "Checking for PR template..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/session-to-obsidian.py",
            "async": true,
            "statusMessage": "Exporting session to Obsidian...",
            "timeout": 30
          }
        ]
      }
    ]
