          { "type": "command", "command": "python3 hooks/branch-enforcer.py" },
          { "type": "command", "command": "python3 hooks/push-guard.py" },
          { "type": "command", "command": "python3 hooks/block-attribution.py" }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          { "type": "command", "command": "python3 hooks/file-protector.py" }
