# direnv config — auto-activates the project venv on cd into this repo.
#
# Without this, `make test` and ad-hoc `python3` calls resolve to the
# system Python (Apple's /usr/bin/python3 = 3.9.6 on macOS), and any
# code using Python 3.10+ syntax (e.g. `zip(strict=True)` from
# round-50 B905) fails locally even though CI passes on 3.10+.
#
# Setup:
#   brew install direnv
#   eval "$(direnv hook zsh)"   # add to ~/.zshrc
#   direnv allow                # one-time, per repo
#
# The .venv path itself is bootstrapped by `make check-deps` / SETUP.md.

source .venv/bin/activate
