# Coverage config — keep `make test-cov` honest.
#
# Most hook tests under tests/hooks/ exercise the hooks by running them as
# subprocesses (see tests/conftest.py::run_hook). coverage.py does not
# instrument subprocesses by default, so those files showed 0% coverage in
# the report even though they have hundreds of behavioral tests against
# them. That made the headline coverage number meaningless.
#
# Two principled choices:
#   1. Configure subprocess coverage tracking (COVERAGE_PROCESS_START +
#      .pth files in site-packages). Real, accurate, but invasive to set up.
#   2. Omit subprocess-tested hooks from the report so the number reflects
#      the code that actually IS line-tested in-process.
#
# We pick (2). The hooks are tested — just not by coverage.py. The number
# you see now is the coverage of `lib/` (where line coverage is the right
# metric) and the one hook that's tested via importlib direct import
# (session-to-obsidian.py, ~70% covered).

[run]
source = hooks, lib
omit =
    # Subprocess-tested hooks — see comment above.
    hooks/_git.py
    hooks/audit-log.py
    hooks/block-attribution.py
    hooks/branch-enforcer.py
    hooks/compact-reinject.py
    hooks/draft-before-create.py
    hooks/file-protector.py
    hooks/notify.py
    hooks/pr-template-reminder.py
    hooks/push-guard.py
    hooks/secret-scan.py

[report]
# Surface lines coverage.py thinks aren't reached. Helpful when you add
# a new branch to a lib helper and forget the matching test.
show_missing = True
skip_covered = False
