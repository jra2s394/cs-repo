# Coverage config — measures both in-process tests AND subprocess-tested
# hooks. Most hook tests under tests/hooks/ run the hook scripts as
# subprocesses (see tests/conftest.py::run_hook), so we use coverage.py's
# parallel + subprocess-init mechanism:
#
#   1. `parallel = True` makes each process write to its own
#      .coverage.HOST.PID.RND file instead of overwriting a single
#      .coverage file.
#   2. The `a1_coverage.pth` file (auto-installed by `pip install
#      coverage`) calls `coverage.process_startup()` whenever a Python
#      process starts with COVERAGE_PROCESS_START set in its env.
#   3. tests/conftest.py sets COVERAGE_PROCESS_START and COVERAGE_FILE
#      to absolute paths so every subprocess — even ones launched with
#      `cwd=tmp_path` — writes data into the repo root where pytest-cov
#      finds and combines them.
#   4. pytest-cov's --cov flag automatically runs `coverage combine`
#      after pytest exits.
#
# Was: rounds 42-43 omitted the subprocess-tested hooks (11 files) because
# coverage.py couldn't see them. Round 62 wired subprocess tracking so we
# can drop the omit list and the headline number now reflects real
# behavioral coverage across most of the hook surface.

[run]
source = hooks, lib
parallel = True

[report]
# Surface lines coverage.py thinks aren't reached. Helpful when you add
# a new branch to a lib helper and forget the matching test.
show_missing = True
skip_covered = False
