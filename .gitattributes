# Normalize line endings to LF on commit; check out native on Windows for text files.
* text=auto eol=lf

# Force LF on shell, source, and config — avoids subtle bugs from CRLF line endings.
*.sh   text eol=lf
*.py   text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.md   text eol=lf
*.toml text eol=lf
*.cfg  text eol=lf

# Mark binaries explicitly so git doesn't try to diff or normalize them.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.docx binary
*.xlsx binary
*.zip  binary
