node_modules/
.env
.env.*
!.env.example
.DS_Store

# Don't commit generated outputs by default
data/outputs/*
!data/outputs/.gitkeep

# Report builder artifacts (generated at runtime)
assets/
out/

# Finance data files — never commit customer or billing data
*.xlsx
*.csv
*.pdf
*.docx

# Claude Code local state
.claude/projects/
.claude/cache/
.claude/settings.local.json
.claude/*.lock
.mcp.json

# Test runner caches
.pytest_cache/
.ruff_cache/
__pycache__/
*.pyc

# pytest-cov data file (config lives in .coveragerc, which IS committed)
.coverage
.coverage.*
htmlcov/

# Build / virtualenv artifacts
.venv/
venv/
dist/
build/
*.tmp
*.log

# Editor / IDE local state
.vscode/
.idea/

# History-rewrite substitution rules — the file contains real PII strings
# being scrubbed, so it must never be committed. Use rewrite-rules.example.txt
# as the template (committed) and copy to rewrite-rules.local.txt (ignored).
scripts/rewrite-rules.local.txt
